<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.stage.FileChooser?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import java.lang.String?>


<VBox spacing="10" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ocrconverter.TextConverterGUIController" styleClass="root">
    

    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>
    <HBox spacing="10" styleClass="hbox">
        <Label text="Image Path:" styleClass="label"/>
        <Label fx:id="imagePathLabel" text="No image selected" HBox.hgrow="ALWAYS" styleClass="path-label"/>
        <Button fx:id="browseButton" text="Browse..." onAction="#handleBrowseButtonAction" styleClass="button"/>
    </HBox>
    <GridPane hgap="20" vgap="10">
    <ProgressBar fx:id="progressBar" prefWidth="400.0" visible="false" VBox.vgrow="NEVER"/>
    
        <columnConstraints>
            <ColumnConstraints hgrow="NEVER" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>
        <ImageView fx:id="imageView" fitWidth="300" preserveRatio="true" GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.rowSpan="2"/>
        <VBox GridPane.columnIndex="0" GridPane.rowIndex="1" alignment="BOTTOM_LEFT">
            <ComboBox fx:id="languageComboBox" prefWidth="200.0" promptText="Select Language" styleClass="combo-box"/>
            <Button fx:id="convertButton" text="Convert to Text" onAction="#handleConvertButtonAction" disable="true" styleClass="button convert-button"/>
        </VBox>
        <ScrollPane VBox.vgrow="ALWAYS" styleClass="scroll-pane" GridPane.columnIndex="1" GridPane.rowIndex="0">
            <TextArea fx:id="outputTextArea" editable="false" prefHeight="200.0" prefWidth="400.0" styleClass="text-area output-text-area"/>
        </ScrollPane>
    </GridPane>
</VBox>
